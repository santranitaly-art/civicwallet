# =============================================================
# CivicWallet — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit the actual .env.local to version control.

# ─── DATABASE (PostgreSQL 16 — VPS Aruba) ──────────────────
# Connessione diretta al PostgreSQL locale sul VPS.
# NON usare pgbouncer/pooler — connessione diretta via socket/TCP locale.
DATABASE_URL="postgresql://civicwallet_user:STRONG_PASSWORD_HERE@localhost:5432/civicwallet_db"
# DIRECT_URL rimosso: non necessario senza Supabase connection pooler

# ─── THIRDWEB (SDK + Auth) ──────────────────────────────────
# Ottieni da: https://thirdweb.com/dashboard
NEXT_PUBLIC_THIRDWEB_CLIENT_ID="your-thirdweb-client-id"
THIRDWEB_SECRET_KEY="your-thirdweb-secret-key"

# ─── BLOCKCHAIN (Polygon PoS) ───────────────────────────────
NEXT_PUBLIC_CHAIN_ID="137"
NEXT_PUBLIC_CONTRACT_ADDRESS="0x..."
# RPC endpoint Polygon (Alchemy/Infura/Thirdweb RPC)
POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY"
# Per testnet Amoy (sviluppo):
POLYGON_AMOY_RPC_URL="https://rpc-amoy.polygon.technology"
# Chiave privata del wallet Relayer (MINTER_ROLE) — MAI esporre pubblicamente
DEPLOYER_PRIVATE_KEY="0x..."

# ─── BACKEND WALLET (per minting server-side) ───────────────
BACKEND_WALLET_ADDRESS="0x..."

# ─── WEBHOOK SECURITY ───────────────────────────────────────
# Segreto HMAC condiviso con AppAmbulanza (su stesso VPS = comunicazione interna)
APPAMBULANZA_WEBHOOK_SECRET="hmac-secret-shared-with-appambulanza"
# Genera con: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET="your-random-hex-32"

# ─── QR TOKEN SIGNING ───────────────────────────────────────
QR_JWT_SECRET="your-random-256-bit-secret"
QR_TOKEN_EXPIRY_MINUTES="5"

# ─── EMAIL (Notifiche) ──────────────────────────────────────
# Usa lo stesso Gmail SMTP di AppAmbulanza o SMTP dedicato
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply.civicwallet@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
EMAIL_FROM="CivicWallet <noreply.civicwallet@gmail.com>"

# ─── APPLICATION ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CivicWallet"
NODE_ENV="development"
